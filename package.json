{
  "name": "@altertable/lakehouse",
  "version": "0.2.1",
  "description": "Altertable Lakehouse JS/TS API client",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
